<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Azael — Marketing, video and visual content in White Plains, NY. Your brand deserves to look like what it's worth.">
<meta name="keywords" content="marketing digital white plains, food photography new york, video marketing ny, reels advertising, visual content agency white plains ny">
<title>Azael — Your brand deserves to look like what it's worth</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#080808;--ink2:#0e0e0e;--violet:#BB00FF;--magenta:#EB1E88;--acid:#FF007A;
  --white:#f5f4f0;--muted:rgba(245,244,240,0.45);--gb:rgba(255,255,255,0.13);
}
html{scroll-behavior:smooth}
body{background:var(--ink);color:var(--white);font-family:'Outfit',sans-serif;overflow-x:hidden;cursor:none}
.cursor{position:fixed;width:10px;height:10px;border-radius:50%;background:var(--magenta);pointer-events:none;z-index:9999;transform:translate(-50%,-50%);mix-blend-mode:exclusion;transition:width .3s,height .3s}
.cursor-ring{position:fixed;width:36px;height:36px;border-radius:50%;border:1px solid rgba(187,0,255,0.55);pointer-events:none;z-index:9998;transform:translate(-50%,-50%);mix-blend-mode:exclusion}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:var(--ink)}::-webkit-scrollbar-thumb{background:linear-gradient(var(--violet),var(--magenta))}
nav{position:fixed;top:0;left:0;right:0;z-index:500;padding:1.4rem 5%;display:flex;align-items:center;justify-content:space-between;transition:all .4s}
nav.scrolled{background:rgba(8,8,8,0.9);backdrop-filter:blur(24px);border-bottom:1px solid var(--gb)}
.nav-logo{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:.12em;color:var(--white);text-decoration:none}
.nav-logo span{color:var(--magenta)}
.nav-links{display:flex;gap:2.5rem;list-style:none}
.nav-links a{color:var(--muted);text-decoration:none;font-size:.82rem;font-weight:500;letter-spacing:.1em;text-transform:uppercase;transition:color .2s}
.nav-links a:hover{color:var(--white)}
.nav-cta{font-family:'Bebas Neue',sans-serif;letter-spacing:.12em;font-size:1rem;padding:.6rem 1.6rem;border-radius:4px;
  background:linear-gradient(135deg,rgba(255,255,255,0.10),rgba(255,255,255,0.04));
  backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,0.18);
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.22);color:var(--white);text-decoration:none;transition:all .2s}
.nav-cta:hover{border-color:var(--violet);box-shadow:0 0 20px rgba(187,0,255,0.3),inset 0 1px 0 rgba(255,255,255,0.22)}
.nav-burger{display:none;flex-direction:column;gap:6px;cursor:pointer;background:none;border:none;padding:4px}
.nav-burger span{display:block;width:28px;height:1.5px;background:var(--white);transition:.3s}
.mobile-menu{display:none;position:fixed;inset:0;z-index:490;background:rgba(8,8,8,0.97);backdrop-filter:blur(20px);flex-direction:column;align-items:center;justify-content:center;gap:2.5rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-family:'Bebas Neue',sans-serif;font-size:3rem;letter-spacing:.1em;color:var(--white);text-decoration:none;transition:color .2s}
.mobile-menu a:hover{color:var(--magenta)}
.mobile-menu .close-btn{position:absolute;top:1.8rem;right:5%;background:none;border:none;color:var(--white);font-size:2rem;cursor:pointer}
#hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;align-items:center;padding:0 5%;padding-top:7rem;gap:4rem;position:relative;overflow:hidden}
.hero-noise{position:absolute;inset:0;opacity:.025;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-size:256px;pointer-events:none}
.hero-glow{position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(187,0,255,0.28) 0%,transparent 70%);top:-200px;right:-100px;pointer-events:none;animation:gpulse 6s ease-in-out infinite}
.hero-glow2{position:absolute;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(235,30,136,0.2) 0%,transparent 70%);bottom:-100px;left:20%;pointer-events:none;animation:gpulse 8s ease-in-out infinite 2s}
@keyframes gpulse{0%,100%{transform:scale(1)}50%{transform:scale(1.1)}}
.hero-left{position:relative;z-index:2}
.hero-tag{display:inline-flex;align-items:center;gap:.6rem;margin-bottom:2rem;opacity:0;animation:fup .8s ease .2s forwards}
.hero-tag-line{width:40px;height:1px;background:var(--magenta)}
.hero-tag span{font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--magenta);font-weight:500}
.hero-h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(5rem,9vw,9.5rem);line-height:.92;letter-spacing:.02em;margin-bottom:1.8rem;opacity:0;animation:fup .8s ease .35s forwards}
.hero-h1 .outline{-webkit-text-stroke:1.5px var(--white);color:transparent}
.hero-h1 .outline-m{-webkit-text-stroke:1.5px var(--magenta);color:transparent}
.hero-h1 .italic{font-family:'DM Serif Display',serif;font-style:italic;color:var(--magenta)}
.hero-sub{font-size:1.05rem;font-weight:300;color:var(--muted);line-height:1.8;max-width:420px;margin-bottom:3rem;opacity:0;animation:fup .8s ease .5s forwards}
.hero-sub strong{color:var(--white);font-weight:500}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap;opacity:0;animation:fup .8s ease .65s forwards}
.btn-primary{font-family:'Bebas Neue',sans-serif;letter-spacing:.12em;font-size:1.1rem;padding:.9rem 2.4rem;background:linear-gradient(135deg,var(--violet),var(--magenta));color:#fff;border-radius:4px;text-decoration:none;transition:all .2s;border:none;cursor:pointer;box-shadow:0 0 28px rgba(187,0,255,0.35)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 0 45px rgba(187,0,255,0.55)}
.btn-ghost{font-family:'Bebas Neue',sans-serif;letter-spacing:.12em;font-size:1.1rem;padding:.9rem 2.4rem;
  background:linear-gradient(135deg,rgba(255,255,255,0.10),rgba(255,255,255,0.04));
  backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
  border:1px solid rgba(255,255,255,0.16);
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.22),0 4px 16px rgba(0,0,0,0.3);
  color:var(--white);border-radius:4px;text-decoration:none;transition:all .2s;position:relative;overflow:hidden}
.btn-ghost::before{content:'';position:absolute;top:0;left:0;right:0;height:50%;background:linear-gradient(180deg,rgba(255,255,255,0.08),transparent);pointer-events:none}
.btn-ghost:hover{border-color:rgba(255,255,255,0.3);box-shadow:inset 0 1px 0 rgba(255,255,255,0.28),0 0 20px rgba(187,0,255,0.2)}
.hero-right{position:relative;z-index:2;opacity:0;animation:fup .8s ease .5s forwards}
.hero-img-wrap{position:relative;border-radius:8px;overflow:hidden;aspect-ratio:4/5}
.hero-img-wrap img{width:100%;height:100%;object-fit:cover;display:block}
.hero-img-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,0.6) 0%,transparent 50%)}
.hero-img-badge{position:absolute;bottom:1.5rem;left:1.5rem;
  background:linear-gradient(135deg,rgba(255,255,255,0.12),rgba(255,255,255,0.04));
  backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
  border:1px solid rgba(255,255,255,0.18);border-radius:8px;padding:1rem 1.2rem;
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.22)}
.hero-img-badge .num{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;letter-spacing:.05em;background:linear-gradient(135deg,var(--violet),var(--magenta));-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1}
.hero-img-badge .lbl{font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.hero-bottom{grid-column:1/-1;display:flex;justify-content:space-between;align-items:center;padding:2rem 0;border-top:1px solid var(--gb);opacity:0;animation:fup .8s ease .8s forwards}
.hero-stat .n{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:.05em;color:var(--white)}
.hero-stat .l{font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.hero-divider{width:1px;height:36px;background:var(--gb)}
@keyframes fup{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
.ticker{overflow:hidden;padding:1rem 0;background:linear-gradient(90deg,var(--violet),var(--magenta),var(--acid),var(--violet));background-size:300%;animation:tbg 8s linear infinite}
.ticker-track{display:flex;width:max-content;animation:tmove 22s linear infinite}
.ticker-item{display:flex;align-items:center;gap:2rem;padding:0 2rem;font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:.12em;color:#fff;white-space:nowrap}
.ticker-item::after{content:'✦';font-size:.7rem;opacity:.6}
@keyframes tmove{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes tbg{0%{background-position:0%}100%{background-position:300%}}
.s-pad{padding:8rem 5%}
.s-label{font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--magenta);font-weight:500;margin-bottom:1rem;display:flex;align-items:center;gap:.8rem}
.s-label::before{content:'';width:30px;height:1px;background:linear-gradient(90deg,var(--violet),var(--magenta))}
.s-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(3rem,6vw,6rem);line-height:.95;letter-spacing:.02em;margin-bottom:1.5rem}
.s-title .outline{-webkit-text-stroke:1px var(--white);color:transparent}
.s-title .italic{font-family:'DM Serif Display',serif;font-style:italic;color:var(--magenta)}
.s-body{font-size:1rem;font-weight:300;color:var(--muted);line-height:1.8;max-width:500px}

/* ── SERVICES ── */
#services{background:var(--ink);position:relative;overflow:hidden}
.svc-orb{position:absolute;border-radius:50%;pointer-events:none;filter:blur(90px);z-index:0}
.svc-orb-1{width:480px;height:480px;top:-120px;left:-60px;background:rgba(187,0,255,0.22)}
.svc-orb-2{width:400px;height:400px;bottom:-80px;right:-60px;background:rgba(235,30,136,0.18)}
.svc-orb-3{width:280px;height:280px;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(187,0,255,0.10)}
.svc-inner{position:relative;z-index:1}
.svc-header{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:2rem;margin-bottom:3rem}
.svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}
.svc-card{
  border-radius:16px;overflow:hidden;position:relative;cursor:default;aspect-ratio:4/3;
  background:linear-gradient(135deg,rgba(255,255,255,0.11) 0%,rgba(255,255,255,0.04) 50%,rgba(187,0,255,0.08) 100%);
  backdrop-filter:blur(14px) saturate(160%);-webkit-backdrop-filter:blur(14px) saturate(160%);
  border:1px solid rgba(255,255,255,0.14);
  box-shadow:inset 0 1.5px 0 rgba(255,255,255,0.28),inset 0 -1px 0 rgba(0,0,0,0.15),0 4px 24px rgba(0,0,0,0.45);
  transition:transform .45s cubic-bezier(.16,1,.3,1),border-color .3s,box-shadow .3s;
}
.svc-card::before{content:'';position:absolute;top:0;left:0;right:0;height:45%;background:linear-gradient(180deg,rgba(255,255,255,0.14) 0%,transparent 100%);border-radius:16px 16px 0 0;pointer-events:none;z-index:2}
.svc-card::after{content:'';position:absolute;top:-0.5px;left:15%;right:15%;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.55),transparent);pointer-events:none;z-index:3}
.svc-card:hover{transform:translateY(-7px) scale(1.025);border-color:rgba(187,0,255,0.45);box-shadow:inset 0 1.5px 0 rgba(255,255,255,0.32),0 18px 50px rgba(187,0,255,0.30),0 0 0 1px rgba(187,0,255,0.18)}
.svc-card:nth-child(even):hover{border-color:rgba(235,30,136,0.45);box-shadow:inset 0 1.5px 0 rgba(255,255,255,0.32),0 18px 50px rgba(235,30,136,0.25),0 0 0 1px rgba(235,30,136,0.18)}
.svc-card-inner{position:relative;z-index:4;height:100%;padding:1.4rem 1.5rem;display:flex;flex-direction:column;justify-content:space-between}
.svc-card-num{font-family:'Bebas Neue',sans-serif;font-size:.7rem;letter-spacing:.2em;color:rgba(255,255,255,0.25)}
.svc-card h3{font-family:'Bebas Neue',sans-serif;font-size:clamp(1.1rem,1.8vw,1.55rem);letter-spacing:.03em;line-height:1.05;background:linear-gradient(135deg,rgba(255,255,255,0.92),rgba(255,255,255,0.55));-webkit-background-clip:text;-webkit-text-fill-color:transparent;transition:all .3s}
.svc-card:hover h3{background:linear-gradient(135deg,var(--violet),var(--magenta));-webkit-background-clip:text;-webkit-text-fill-color:transparent}

/* ── PORTFOLIO ── */
#portfolio{background:var(--ink)}
.port-intro{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:3rem;flex-wrap:wrap;gap:2rem}
.port-grid{display:grid;grid-template-columns:repeat(12,1fr);gap:.8rem}
.p-item{border-radius:8px;overflow:hidden;position:relative;background:#111}
.p-item img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .65s cubic-bezier(.25,.46,.45,.94)}
.p-item:hover img{transform:scale(1.05)}
.p-item:nth-child(1){grid-column:1/7;aspect-ratio:4/3}
.p-item:nth-child(2){grid-column:7/13;aspect-ratio:4/3}
.p-item:nth-child(3){grid-column:1/5;aspect-ratio:1/1}
.p-item:nth-child(4){grid-column:5/9;aspect-ratio:1/1}
.p-item:nth-child(5){grid-column:9/13;aspect-ratio:1/1}
.p-item:nth-child(6){grid-column:1/7;aspect-ratio:16/9}
.p-item:nth-child(7){grid-column:7/13;aspect-ratio:16/9;background:var(--ink2);border:1px dashed rgba(187,0,255,0.2);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1rem;cursor:default}
.p-info{position:absolute;inset:0;opacity:0;transition:opacity .35s ease;display:flex;align-items:flex-end;padding:1.2rem;z-index:2;background:linear-gradient(to top,rgba(8,8,8,0.65) 0%,rgba(8,8,8,0.1) 50%,transparent 80%)}
.p-item:hover .p-info{opacity:1}
.p-glass-label{background:rgba(255,255,255,0.10);backdrop-filter:blur(10px) saturate(140%);-webkit-backdrop-filter:blur(10px) saturate(140%);border:1px solid rgba(255,255,255,0.18);border-radius:10px;padding:.65rem 1rem;position:relative;overflow:hidden;box-shadow:inset 0 1px 0 rgba(255,255,255,0.24),0 4px 12px rgba(0,0,0,0.35)}
.p-glass-label::before{content:'';position:absolute;top:0;left:0;right:0;height:50%;background:linear-gradient(180deg,rgba(255,255,255,0.10),transparent);pointer-events:none}
.p-tag{font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,0.65);margin-bottom:.2rem;position:relative;z-index:1}
.p-name{font-family:'Bebas Neue',sans-serif;font-size:1.15rem;letter-spacing:.05em;position:relative;z-index:1}
.reel-box{margin-top:3rem;border-radius:8px;overflow:hidden;position:relative;aspect-ratio:16/9;background:var(--ink2);border:1px solid var(--gb);display:flex;align-items:center;justify-content:center}
.play-circle{width:84px;height:84px;border-radius:50%;background:linear-gradient(135deg,var(--violet),var(--magenta));display:flex;align-items:center;justify-content:center;cursor:pointer;transition:transform .3s,box-shadow .3s;box-shadow:0 0 40px rgba(187,0,255,0.45)}
.play-circle:hover{transform:scale(1.1);box-shadow:0 0 60px rgba(187,0,255,0.7)}
.play-circle svg{width:28px;height:28px;fill:#fff;margin-left:4px}
.reel-label{font-family:'Bebas Neue',sans-serif;letter-spacing:.15em;font-size:1rem;color:var(--muted);text-align:center;margin-top:1.2rem}

/* ── INSIGHTS ── */
#insights{background:var(--ink);position:relative;overflow:hidden}
.insights-big{font-family:'Bebas Neue',sans-serif;font-size:clamp(7rem,14vw,14rem);line-height:.88;color:transparent;-webkit-text-stroke:1px rgba(187,0,255,0.18);position:absolute;top:3rem;left:5%;pointer-events:none;user-select:none;text-shadow:0 0 50px rgba(187,0,255,0.6),0 0 100px rgba(187,0,255,0.35),0 0 150px rgba(235,30,136,0.2);animation:dglow 4s ease-in-out infinite}
@keyframes dglow{0%,100%{text-shadow:0 0 40px rgba(187,0,255,0.5),0 0 80px rgba(187,0,255,0.28),0 0 140px rgba(235,30,136,0.15);-webkit-text-stroke-color:rgba(187,0,255,0.16)}50%{text-shadow:0 0 70px rgba(187,0,255,0.9),0 0 130px rgba(187,0,255,0.5),0 0 200px rgba(235,30,136,0.4);-webkit-text-stroke-color:rgba(235,30,136,0.28)}}
.insights-content{position:relative;z-index:2}
.insights-header{max-width:620px;margin-bottom:5rem}
.insights-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--gb);border:1px solid var(--gb);border-radius:6px;overflow:hidden}
.ins-card{background:var(--ink);padding:2.8rem 2.2rem;transition:background .3s}
.ins-card:hover{background:var(--ink2)}
.ins-num{font-family:'Bebas Neue',sans-serif;font-size:3.8rem;letter-spacing:.03em;line-height:1;margin-bottom:.7rem;background:linear-gradient(135deg,var(--violet),var(--magenta));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.ins-text{font-size:.87rem;font-weight:300;color:var(--muted);line-height:1.65}
.ins-text strong{color:var(--white);font-weight:500}

/* ── PROCESS ── */
#process{background:var(--ink2)}
.process-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:5rem;flex-wrap:wrap;gap:2rem}
.process-track{display:flex;gap:0;position:relative}
.process-track::before{content:'';position:absolute;top:2.5rem;left:0;right:0;height:1px;background:var(--gb)}
.p-step{flex:1;padding:0 1.5rem;position:relative;z-index:1;text-align:center}
.p-step-num{width:5rem;height:5rem;border-radius:50%;background:var(--ink2);border:1px solid var(--gb);display:flex;align-items:center;justify-content:center;margin:0 auto 1.8rem;font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:var(--muted);transition:all .3s}
.p-step:hover .p-step-num{background:linear-gradient(135deg,var(--violet),var(--magenta));color:#fff;border-color:var(--violet)}
.p-step h3{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:.06em;margin-bottom:.5rem}
.p-step p{font-size:.82rem;color:var(--muted);line-height:1.65;font-weight:300}

/* ── CONTACT ── */
#contact{background:var(--ink)}
.contact-grid{display:grid;grid-template-columns:5fr 7fr;gap:6rem;align-items:start}
.c-links{display:flex;flex-direction:column;gap:.8rem;margin-top:2.5rem}
.c-link{display:flex;align-items:center;gap:1.2rem;padding:1rem 1.3rem;background:linear-gradient(135deg,rgba(255,255,255,0.07),rgba(255,255,255,0.02));backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.10);box-shadow:inset 0 1px 0 rgba(255,255,255,0.14);border-radius:8px;color:var(--white);text-decoration:none;transition:all .25s}
.c-link:hover{border-color:rgba(187,0,255,0.4);box-shadow:inset 0 1px 0 rgba(255,255,255,0.2),0 0 20px rgba(187,0,255,0.15);transform:translateX(4px)}
.c-icon{font-size:1.1rem;width:32px;text-align:center;color:var(--muted);transition:color .25s}
.c-link:hover .c-icon{color:var(--violet)}
.c-txt small{display:block;font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:.12rem}
.c-txt strong{font-size:.9rem;font-weight:500}
.c-form{background:linear-gradient(135deg,rgba(255,255,255,0.08),rgba(255,255,255,0.03) 60%,rgba(187,0,255,0.06) 100%);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,0.12);box-shadow:inset 0 1px 0 rgba(255,255,255,0.18),0 20px 60px rgba(0,0,0,0.5);border-radius:16px;padding:2.5rem}
.f-row{margin-bottom:1.1rem}
.f-row label{display:block;font-size:.67rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:.45rem;font-weight:500}
