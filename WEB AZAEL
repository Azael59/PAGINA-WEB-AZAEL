  document.querySelectorAll('.reveal,.reveal-scale').forEach(function(el){io.observe(el)});
})();
var VIDEO_URLS={1:'REEL_1_URL.mp4',2:'REEL_2_URL.mp4',3:'HORIZ_VIDEO_URL.mp4'};
function activateVideo(n){
  var url=VIDEO_URLS[n],slot=document.getElementById('vslot'+n);
  if(!url||url.indexOf('_URL')!==-1){alert('Open the HTML file and replace the URL for video '+n+' in the VIDEO_URLS object at the top of the script.');return;}
  if(url.indexOf('youtube')!==-1||url.indexOf('youtu.be')!==-1){
    var id=url.indexOf('v=')!==-1?url.split('v=')[1].split('&')[0]:url.split('/').pop();
    slot.innerHTML='<iframe src="https://www.youtube.com/embed/'+id+'?autoplay=1" style="width:100%;height:100%;border:none" allowfullscreen allow="autoplay"></iframe>';
  } else {
    slot.innerHTML='<video autoplay controls playsinline style="width:100%;height:100%;object-fit:cover" src="'+url+'"></video>';
  }
}
function handleSubmit(e,form){
  e.preventDefault();
  var btn=form.querySelector('button[type=submit]');
  btn.textContent='Sending...';btn.disabled=true;
  fetch(form.action,{method:'POST',body:new FormData(form),headers:{'Accept':'application/json'}})
    .then(function(r){
      if(r.ok){btn.textContent='Message sent! I will write back soon.';btn.style.background='linear-gradient(135deg,#27ae60,#2d8f4e)'}
      else{btn.textContent='Error. Please email me directly.';btn.style.background='#c0392b';btn.disabled=false}
    })
    .catch(function(){btn.textContent='Error. Please email me directly.';btn.style.background='#c0392b';btn.disabled=false});
}
</script>
